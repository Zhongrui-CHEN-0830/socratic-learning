# ============================================================
# 墨韵书院 — 环境变量配置模板
# 复制到 server/.env 和 frontend/.env.local 并填写真实值
# ============================================================

# --- Server (.env) ---
PORT=3000
NODE_ENV=production

# Supabase 项目设置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# JWT 密钥（生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
JWT_SECRET=change-this-to-a-very-long-random-secret-string-minimum-32-chars

# AES-256 加密密钥（生成命令同上）
ENCRYPTION_KEY=change-this-to-a-32-character-random-string

# --- Frontend (.env.local) ---
# 在 Supabase 项目设置 > API 中获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
